# Copy this file to .env and fill in the values before running docker compose up.
# .env is gitignored — never commit real credentials.

# ---- Required ----
POSTGRES_PASSWORD=
JWT_KEY=                          # min 32 random characters
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=              # min 8 characters

# ---- Optional (have defaults) ----
POSTGRES_USER=postgres
MINIO_BUCKET=products
MINIO_PUBLIC_ENDPOINT=http://localhost:9000   # browser-accessible MinIO URL
FRONTEND_URL=http://localhost:5173

# ---- Email (optional — app starts without it, emails will silently fail) ----
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_FROM_EMAIL=
